# Copy to .env.local (gitignored). Baked into the build at compile time.

# Cloudflare Turnstile site key. Use 1x00000000000000000000AA for "always passes" testing.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Where the frontend POSTs the signup. Leave empty for same-origin — the Worker
# is route-bound to siftly.me/api/beta in workers/beta-signup/wrangler.toml.
# Override only for local dev against a workers.dev URL.
VITE_API_BASE_URL=
