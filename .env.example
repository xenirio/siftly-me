# Copy to .env.local (gitignored). Both vars are baked into the build at compile time.

# Turnstile site key. Use 1x00000000000000000000AA for "always passes" testing.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Where the frontend POSTs the signup. Leave empty for same-origin (production with
# the Worker bound to a custom domain). For interim testing, set to the Worker's
# https://<worker>.<acct>.workers.dev URL — no trailing slash.
VITE_API_BASE_URL=
